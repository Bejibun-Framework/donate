# Copy to server/.dev.vars for local `wrangler dev` — this file is gitignored.
# Values here override the [vars] in wrangler.toml for local development only.

# Wallet address that receives the USDC payments (Base)
PAY_TO_ADDRESS=0xYourWalletAddressHere
SOLANA_PAY_TO_ADDRESS=0xYourWalletAddressHere

# Public testnet facilitator (verifies + settles payments on your behalf)
FACILITATOR_URL=https://x402.org/facilitator

# Optional: use Coinbase's hosted facilitator instead of the public one.
# In production, set these with `wrangler secret put CDP_API_KEY_ID` etc.
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_ID=